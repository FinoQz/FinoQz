# =======================================
# FinoQz Backend Environment Variables
# =======================================

# --- Database Configuration ---
MONGO_URI=mongodb://localhost:27017/finoqz
# For MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/finoqz?retryWrites=true&w=majority

# Optional MongoDB Configuration
DB_SERVER_TIMEOUT=10000
DB_SOCKET_TIMEOUT=45000
DB_MAX_POOL=50
DB_MIN_POOL=5
DB_AUTO_INDEX=false
DB_SSL=false
# DB_REPLICA_SET=

# --- JWT & Authentication ---
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ADMIN_JWT_SECRET=your-admin-jwt-secret-key-change-this

# --- Server Configuration ---
PORT=3000
NODE_ENV=development
# NODE_ENV=production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# --- Redis Configuration ---
# If not set, a mock Redis client will be used
REDIS_URL=redis://localhost:6379
# For Upstash or cloud Redis (with TLS):
# REDIS_URL=rediss://default:password@host:port

# --- Email Configuration ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@finoqz.com

# Alternative: Resend API
# RESEND_API_KEY=re_xxxxxxxxxxxxx

# --- Payment Gateway Configuration ---
# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# --- File Storage ---
# Cloudinary (for images, PDFs, certificates)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Socket.io Configuration ---
SOCKET_SECRET=your-socket-secret-key
SOCKET_STRICT_AUTH=true

# --- Security ---
# Admin webhook secret for internal calls
ADMIN_WEBHOOK_SECRET=your-webhook-secret

# --- AI/ML Services (Optional) ---
# Google Generative AI
GOOGLE_API_KEY=your_google_api_key

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# --- Firebase (Optional) ---
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-app.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef

# --- MojoAuth (Optional) ---
MOJOAUTH_API_KEY=your_mojoauth_api_key

# --- Logging ---
LOG_LEVEL=info
# LOG_LEVEL=debug

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Session Configuration ---
SESSION_SECRET=your-session-secret-key

# =======================================
# Production Deployment Notes:
# =======================================
# 1. Change all secrets and keys to strong, random values
# 2. Set NODE_ENV=production
# 3. Use proper MongoDB Atlas connection string
# 4. Configure Redis with TLS (rediss://)
# 5. Set up proper email service
# 6. Configure payment gateways with production keys
# 7. Set up Cloudinary for file storage
# 8. Configure proper CORS origins in server.js
# 9. Enable database SSL if required
# 10. Set up proper logging and monitoring
